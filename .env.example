# Public runtime
# Use /api when frontend and API run in the same Next.js app.
NEXT_PUBLIC_ALLOWED_SITE_HOST=example.com
NEXT_PUBLIC_API_BASE_URL=/api

# Next.js worker count. Leave empty to use half of available CPU cores.
# Example: 2
NEXT_CPU_WORKERS=

# MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=anitium
DB_CONNECTION_LIMIT=100

# Optional single-line MySQL connection. If set, this overrides DB_HOST/DB_PORT/etc.
# DATABASE_URL=mysql://user:password@localhost:3306/anitium

# Auth/session secret. Change this in production.
AUTH_SECRET=change-this-long-random-secret
